{
	"name": "@conference/db",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./schema": "./src/schema/index.ts",
		"./client": "./src/client.ts"
	},
	"scripts": {
		"generate": "drizzle-kit generate --config=drizzle.config.cjs",
		"migrate": "tsx src/migrate.ts",
		"push": "drizzle-kit push --config=drizzle.config.cjs",
		"studio": "drizzle-kit studio --config=drizzle.config.cjs",
		"seed": "tsx src/seed/index.ts",
		"seed:demo": "tsx src/seed/demo.ts",
		"lint": "eslint ."
	},
	"dependencies": {
		"drizzle-orm": "^0.45.2",
		"pg": "^8.13.1",
		"bcryptjs": "^2.4.3",
		"date-fns": "^4.1.0"
	},
	"devDependencies": {
		"@faker-js/faker": "^9.3.0",
		"@types/pg": "^8.11.10",
		"@types/bcryptjs": "^2.4.6",
		"drizzle-kit": "^0.30.1",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2",
		"dotenv": "^16.4.7"
	}
}
